<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <style>
        :root { --primary: #4161df; --dark: #1f2937; --light: #6b7280; --border: #e2e8f0; }
        
        @page { size: A4; margin: 0; }
        body { font-family: 'Helvetica', 'Arial', sans-serif; margin: 0; padding: 0; color: var(--dark); -webkit-print-color-adjust: exact; }
        
        .page { padding: 50px; height: 100vh; position: relative; box-sizing: border-box; }
        
        /* Header Alignment */
        .header { 
            border-bottom: 2px solid var(--primary); 
            padding-bottom: 20px; 
            display: flex; 
            flex-direction: row; /* Force horizontal */
            justify-content: space-between; 
            align-items: flex-end; /* Align bottom of logo with bottom of RERA tag */
        }
        .logo { font-size: 32px; font-weight: 900; color: var(--primary); text-transform: uppercase; letter-spacing: -1.5px; line-height: 1; }
        .rera-tag { font-size: 10px; color: var(--light); text-align: right; line-height: 1.4; font-weight: 600; }

        /* Hero Image */
        .hero { margin-top: 30px; border-radius: 20px; overflow: hidden; height: 380px; background-color: #f3f4f6; box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
        .hero img { width: 100%; height: 100%; object-fit: cover; display: block; }

        /* Main Info Alignment */
        .main-info { 
            margin-top: 35px; 
            display: flex; 
            flex-direction: row;
            justify-content: space-between; 
            align-items: flex-start; 
        }
        .info-left { flex: 1; padding-right: 20px; }
        .title { font-size: 26px; font-weight: 800; color: #111827; line-height: 1.2; margin: 0; }
        .location { font-size: 15px; color: var(--light); margin-top: 8px; font-weight: 500; }
        
        .price-container { text-align: right; }
        .price-label { font-size: 10px; text-transform: uppercase; color: var(--light); font-weight: 700; margin-bottom: 2px; }
        .price { font-size: 28px; color: var(--primary); font-weight: 900; line-height: 1; }

        /* Features Grid Alignment */
        .specs { 
            display: grid; 
            grid-template-columns: repeat(4, 1fr); 
            gap: 15px; 
            margin-top: 35px; 
        }
        .spec-item { 
            background: #f8fafc; 
            padding: 18px 10px; 
            border-radius: 16px; 
            text-align: center; 
            border: 1px solid var(--border);
        }
        .spec-label { font-size: 10px; text-transform: uppercase; color: var(--light); font-weight: 800; margin-bottom: 6px; letter-spacing: 0.5px; }
        .spec-value { font-size: 14px; font-weight: 700; color: #1e293b; }

        /* Description Box */
        .description-box { margin-top: 45px; }
        .section-label { 
            font-size: 13px; 
            font-weight: 800; 
            color: var(--primary); 
            text-transform: uppercase; 
            border-left: 5px solid var(--primary); 
            padding-left: 12px; 
            margin-bottom: 18px; 
            letter-spacing: 1px;
        }
        .description-text { font-size: 13px; line-height: 1.8; color: #4b5563; text-align: justify; }

        /* Footer Alignment */
        .footer { 
            position: absolute; 
            bottom: 50px; 
            left: 50px; 
            right: 50px; 
            border-top: 1px solid #e5e7eb; 
            padding-top: 25px; 
            display: flex; 
            flex-direction: row;
            justify-content: space-between; 
            align-items: center; 
        }
        .agent-info { font-size: 12px; line-height: 1.5; color: #374151; }
        .brand-footer { font-size: 11px; color: var(--light); text-align: right; font-weight: 500; }
        
        .watermark { 
            position: absolute; 
            top: 50%; 
            left: 50%; 
            transform: translate(-50%, -50%) rotate(-45deg); 
            font-size: 90px; 
            color: rgba(65, 97, 223, 0.04); 
            font-weight: 900; 
            z-index: -1; 
            white-space: nowrap;
        }
    </style>
</head>
<body>
    <div class="page">
        <div class="watermark">PROPERTY BULBUL</div>

        <div class="header">
            <div class="logo">PropertyBulbul</div>
            <div class="rera-tag">
                VERIFIED BY AUTHORITY<br>
                REF ID: <%= property._id.toString().substring(0,8).toUpperCase() %>
            </div>
        </div>

        <div class="hero">
            <img src="<%= property.image[0] || 'https://via.placeholder.com/800x400' %>" alt="Property Image">
        </div>

        <div class="main-info">
            <div class="info-left">
                <h1 class="title"><%= property.title %></h1>
                <div class="location">📍 <%= property.location.address %>, <%= property.location.city %></div>
            </div>
            <div class="price-container">
                <div class="price-label">Asking Price</div>
                <div class="price">₹<%= property.price.toLocaleString('en-IN') %></div>
            </div>
        </div>

        <div class="specs">
            <div class="spec-item">
                <div class="spec-label">Configuration</div>
                <div class="spec-value"><%= property.facilities.bedrooms %> BHK Floor</div>
            </div>
            <div class="spec-item">
                <div class="spec-label">Built-up Area</div>
                <div class="spec-value"><%= property.area.value %> <%= property.area.unit %></div>
            </div>
            <div class="spec-item">
                <div class="spec-label">Facing</div>
                <div class="spec-value"><%= property.facing || 'Open View' %></div>
            </div>
            <div class="spec-item">
                <div class="spec-label">Availability</div>
                <div class="spec-value"><%= property.availability %></div>
            </div>
        </div>

        <div class="description-box">
            <div class="section-label">Property Overview</div>
            <div class="description-text">
                <%= property.description %>
            </div>
        </div>

        <div class="footer">
            <div class="agent-info">
                <strong>Sales Inquiry:</strong><br>
                <%= property.userEmail %><br>
                Source: <%= property.postedBy %>
            </div>
            <div class="brand-footer">
                Official Property Brochure<br>
                <strong>propertybulbul.com</strong>
            </div>
        </div>
    </div>
</body>
</html> 